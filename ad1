<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Whis-AI Instagram Ad</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { 
            sans: ['Inter', 'sans-serif'], 
            mono: ['JetBrains Mono', 'monospace'] 
          },
          colors: {
            accent: '#0284c7',
            darkBg: '#050814'
          }
        }
      }
    }
  </script>
  <style>
    body {
      background-color: #1e293b; /* Dark background for your browser */
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
    }
    
    /* Instagram Square Format */
    .ig-post {
      width: 1080px;
      height: 1080px;
      background-color: #050814;
      position: relative;
      overflow: hidden;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      display: flex;
      flex-direction: column;
    }

    /* Background Effects */
    .glow-1 { position: absolute; top: -15%; left: -15%; width: 700px; height: 700px; background: rgba(2, 132, 199, 0.4); border-radius: 50%; filter: blur(150px); pointer-events: none; }
    .glow-2 { position: absolute; bottom: -10%; right: -10%; width: 600px; height: 600px; background: rgba(16, 185, 129, 0.2); border-radius: 50%; filter: blur(120px); pointer-events: none; }
    .grid-bg { position: absolute; inset: 0; background-image: linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; }

    /* UI Card */
    .glass-card {
      background: rgba(15, 20, 35, 0.85);
      backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 32px;
      box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.3);
    }
    
    /* Code Highlighting */
    .keyword { color: #c678dd; } 
    .function { color: #61afef; } 
    .string { color: #98c379; }
  </style>
</head>
<body>

  <div class="ig-post p-16 relative z-0">
    <div class="glow-1"></div>
    <div class="glow-2"></div>
    <div class="grid-bg"></div>

    <div class="relative z-10 flex justify-between items-center mb-12">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-gradient-to-tr from-sky-400 to-accent flex items-center justify-center text-white text-3xl font-bold shadow-lg">
          W
        </div>
        <span class="text-3xl font-bold text-white tracking-wide">Whis-AI</span>
      </div>
      <div class="px-6 py-3 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 text-xl font-bold uppercase tracking-wider flex items-center gap-3">
        <i class="fa-solid fa-shield-check"></i> 100% Undetectable
      </div>
    </div>

    <div class="relative z-10 mb-12 mt-4">
      <h1 class="text-[5.5rem] leading-[1.05] font-extrabold text-white tracking-tight mb-8">
        Your silent <br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-emerald-400">interview partner.</span>
      </h1>
      <p class="text-3xl text-slate-300 leading-relaxed max-w-3xl">
        Aces your technical rounds by listening to the meeting and reading your screen in absolute stealth.
      </p>
    </div>

    <div class="glass-card relative z-10 w-full flex-grow p-10 flex flex-col justify-between overflow-hidden">
      
      <div class="flex items-center justify-between border-b border-white/10 pb-6 mb-8">
        <div class="flex items-center gap-4">
          <div class="flex gap-2">
            <div class="w-4 h-4 rounded-full bg-red-500"></div>
            <div class="w-4 h-4 rounded-full bg-yellow-500"></div>
            <div class="w-4 h-4 rounded-full bg-green-500"></div>
          </div>
          <span class="text-slate-400 font-mono text-xl ml-4"><i class="fa-solid fa-desktop mr-2 text-sky-400"></i> Screen Capture: <span class="text-white">Active</span></span>
        </div>
        <div class="flex items-center gap-3 bg-red-500/10 border border-red-500/20 px-4 py-2 rounded-lg text-red-400 font-mono text-xl animate-pulse">
          <i class="fa-solid fa-microphone-lines"></i> Listening to Zoom...
        </div>
      </div>

      <div class="flex-grow flex flex-col justify-center">
        <div class="text-sky-400 font-bold uppercase tracking-widest text-lg mb-4">Interviewer Question Detected:</div>
        <div class="text-white text-3xl font-medium mb-8">"Can you optimize this to O(n) time complexity?"</div>
        
        <div class="bg-black/40 rounded-2xl p-6 font-mono text-2xl leading-relaxed border-l-4 border-accent">
          <span class="text-accent text-sm uppercase tracking-widest font-bold block mb-3">AI Suggested Code:</span>
          <div><span class="keyword">def</span> <span class="function">optimized_solution</span>(nums):</div>
          <div class="ml-8 text-slate-300">seen = set()</div>
          <div class="ml-8"><span class="keyword">for</span> num <span class="keyword">in</span> nums:</div>
          <div class="ml-16"><span class="keyword">if</span> num <span class="keyword">in</span> seen: <span class="keyword">return</span> num</div>
          <div class="ml-16">seen.add(num)</div>
        </div>
      </div>
    </div>

    <div class="relative z-10 mt-12 flex items-center justify-between">
      <div class="flex items-center gap-8 text-slate-400 text-2xl font-bold">
        <span class="flex items-center gap-2"><i class="fa-brands fa-microsoft text-3xl"></i> Teams</span>
        <span class="flex items-center gap-2"><i class="fa-solid fa-video text-3xl"></i> Zoom</span>
        <span class="flex items-center gap-2"><i class="fa-brands fa-hackerrank text-3xl"></i> HackerRank</span>
      </div>
      <div class="bg-white text-slate-900 px-10 py-5 rounded-full text-2xl font-extrabold shadow-xl flex items-center gap-3">
        Try For Free <i class="fa-solid fa-arrow-right"></i>
      </div>
    </div>

  </div>

</body>
</html>
